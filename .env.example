# Resend（https://resend.com）API キー。Vercel の Environment Variables にも設定。
RESEND_API_KEY=

# 任意: 受信メール（未設定時は info@earth-savers.org）
# CONTACT_TO_EMAIL=info@earth-savers.org

# 任意: 送信元。earth-savers.org を Resend で認証するまでの検証用に
# Resend が案内する onboarding@resend.dev などを指定できる。
# RESEND_FROM=地球防衛群 お問い合わせ <onboarding@resend.dev>
