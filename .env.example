# Resend（https://resend.com）API キー。ローカルは .env.local、本番は Vercel の Environment Variables に設定。
RESEND_API_KEY=

# --- 本番（ドメイン認証後）---
# 1) resend.com/domains で earth-savers.org を Verified にする
# 2) 送信元（認証済みドメインのメール必須）
RESEND_FROM=地球防衛群 <noreply@earth-savers.org>
# 3) お問い合わせの受信先（省略時も API 既定は info@earth-savers.org）
CONTACT_TO_EMAIL=info@earth-savers.org

# --- ドメイン認証「前」のローカル検証だけ ---
# このときは From を onboarding@resend.dev のまま、To を Resend アカウントの自分のメールにする必要あり:
# CONTACT_TO_EMAIL=あなた@gmail.com

# トラブル: 「自分のメールアドレスにしか送れない」→ まだテストモード。上記 1) のドメイン認証を先に完了。
# 届かない → 迷惑メール・Resend の Emails / Logs を確認。
# お問い合わせAPIは (1) 運営宛通知 (2) お客様宛の受付確認メール の2通を送る。

# --- 都度寄付（銀行）---
# 同じ内容が (1) /join/bank-donation の「振込先口座」に表示（サーバー描画）(2) /contact?intent=bank-donation の自動返信メール に使われる。
# 改行可。未設定のときは案内ページはフォーム誘導のみ・メールは一般の受付文面にフォールバック。
BANK_TRANSFER_DETAILS=銀行名：〇〇銀行\n支店：〇〇支店\n口座種別：普通\n口座番号：1234567\n口座名義：ツウダンホウジン　チキュウボウエイグン
# 任意（件名・前文・末尾を変えたいとき）
# BANK_DONATION_REPLY_SUBJECT=【地球防衛群】都度寄付（銀行振込・郵便振替）のご案内
# BANK_DONATION_REPLY_INTRO=この度は…（複数行OK）
# BANK_DONATION_REPLY_FOOTER=※ …（複数行OK）

# --- Stripe 寄付サブスク（マンスリーサポーター）---
# Dashboard: https://dashboard.stripe.com/test/products
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_TANE=price_...
STRIPE_PRICE_MIDORI=price_...
STRIPE_PRICE_MIZU=price_...
STRIPE_PRICE_MORI=price_...
STRIPE_PRICE_YAMA=price_...
STRIPE_PRICE_NANA=price_...
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/test_...

# Supabase（Webhook → memberships 書き込み用・service role）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Checkout / Portal の success URL 用（本番: https://earth-savers.org）
# SITE_URL=https://earth-savers.org
